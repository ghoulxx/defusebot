# Example environment variables for the Discord bot.
# Copy this file to `.env` locally and fill in real values (do NOT commit secrets).
TOKEN=your-discord-bot-token-here
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# Use your hosting provider (Railway, Render, etc.) to set real env vars in production.